@startuml 客户管理-外出健康膳食

skinparam classAttributeIconSize 0
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 10
skinparam dpi 96

skinparam class {
    BorderColor #8B4513
    BorderThickness 1.5
    BackgroundColor #FDF5E6
    FontSize 11
    HeaderBackgroundColor #8B4513
    HeaderFontColor #FFFFFF
}

skinparam abstractClass {
    BorderColor #A0522D
    BorderThickness 1.5
    BackgroundColor #FDF8F3
    FontSize 11
    HeaderBackgroundColor #A0522D
    HeaderFontColor #FFFFFF
    FontStyle italic
}

skinparam package {
    BorderThickness 1.5
    BackgroundColor #FDFAF5
    FontStyle bold
    FontSize 12
    BorderColor #D2B48C
}

skinparam arrow {
    Color #A0522D
    Thickness 1.2
}

skinparam nodesep 20
skinparam ranksep 20

package "model" #FDF0E0 {
    class Elderly <<客户>> {
        - id / name / status
    }

    class OutRegistration <<外出登记>> {
        - outId : String
        - customerId : String
        - outTime : String
        - expectedReturnTime : String
        - actualReturnTime : String
        - companion : String
        - reason : String
        - status : String
    }

    class HealthRecord <<健康记录>> {
        - healthId : String
        - customerId : String
        - recordDate : String
        - bloodPressure : String
        - heartRate : String
        - bloodSugar : String
        - weight : String
        - temperature : String
        - remark : String
    }

    class DietPreference <<膳食偏好>> {
        - preferenceId : String
        - customerId : String
        - preferenceType : String
        - description : String
        - allergies : String
        - taboos : String
        - remark : String
    }
}

package "dao" #F0EDE0 {
    abstract class BaseJsonDao<T> {
        + findAll() / findById()
        + insert / update / delete
        + exists() / load() / save()
    }

    class OutRegistrationDao {
        + findByCustomerId(String)
        + findByStatus(String)
    }

    class HealthRecordDao {
        + findByCustomerId(String)
        + findByDateRange(String, String)
    }

    class DietPreferenceDao {
        + findByCustomerId(String) : DietPreference
    }
}

package "service" #FDF5E6 {
    class OutRegistrationService {
        - dao
        + findAll()
        + findByCustomerId / findByStatus
        + add / update / delete
    }

    class HealthRecordService {
        - dao
        + findAll()
        + findByCustomerId / findByDateRange
        + add / update / delete
    }

    class DietPreferenceService {
        - dao
        + findAll()
        + findByCustomerId()
        + add / update / delete
    }
}

package "gui" #F0E8E0 {
    class AdminFrame {
        外出手续 Tab
        退住管理 Tab
        健康记录 Tab
    }
    class NurseFrame {
        老人信息 Tab
        膳食偏好 Tab
    }
}

BaseJsonDao <|-- OutRegistrationDao
BaseJsonDao <|-- HealthRecordDao
BaseJsonDao <|-- DietPreferenceDao

OutRegistrationService --> OutRegistrationDao
HealthRecordService --> HealthRecordDao
DietPreferenceService --> DietPreferenceDao

OutRegistration ..> Elderly : customerId
HealthRecord ....> Elderly : customerId
DietPreference ..> Elderly : customerId

AdminFrame --> OutRegistrationDao : 外出登记
AdminFrame --> HealthRecordDao : 健康记录
NurseFrame --> DietPreferenceDao : 膳食偏好

@enduml
